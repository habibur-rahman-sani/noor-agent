# ============================================================
# এই ফাইল কপি করে ".env" নাম দিন, তারপর নিচে আপনার key বসান।
#   cp .env.example .env   (Linux/Mac)   |   copy .env.example .env  (Windows)
# .env ফাইল কখনো GitHub-এ push হবে না (.gitignore করা আছে)।
# ============================================================

# ---- OpenRouter (AI মডেল) — openrouter.ai → Keys → Create Key ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL_FREE=openrouter/free

# ---- ওয়েব UI লগইন ----
AGNO_UI_USERNAME=agno
AGNO_UI_PASSWORD=noor12345

# ---- Database (docker-compose নিজে থেকে mongo সার্ভিসে যুক্ত করে) ----
MONGODB_DB_NAME=agno_system

# ---- অটো-আপডেট (GitHub থেকে) ----
AUTO_UPDATE=1
NOOR_REPO_URL=https://github.com/habibur-rahman-sani/noor-agent.git
