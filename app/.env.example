# ==============================================================
# এই ফাইলের নাম পরিবর্তন করে ".env" রাখো এবং আসল key/value বসাও
# .env ফাইল কখনো git-এ commit করো না
# ==============================================================

# ---------- Model (ধাপ ১: ফিক্সড, ধাপ ২: ফ্রি অটো, ধাপ ৩: পেইড) ----------
OPENROUTER_API_KEY=
OPENROUTER_MODEL_FREE=openrouter/free
OPENROUTER_MODEL_PAID=
# টাস্ক-ভিত্তিক ফিক্সড মডেল (ডিফল্ট আছে config.py-তে, চাইলে overwrite করো, slug যাচাই করো openrouter.ai/models-এ)
OPENROUTER_MODEL_CODING=
OPENROUTER_MODEL_REASONING=
OPENROUTER_MODEL_RESEARCH=
OPENROUTER_MODEL_CREATIVE=
OPENROUTER_MODEL_SOCIAL=
# টেক্সট-বিহীন আইকন/বাটন খুঁজে বের করার জন্য (Vision Agent: locate_icon/click_icon) —
# multimodal/vision মডেল লাগে, খালি রাখলে ডিফল্ট ব্যবহার হবে (স্লাগ যাচাই করো openrouter.ai/models-এ)
OPENROUTER_MODEL_VISION=
# LOCAL_MODEL_MODE=1 হলে locate_icon/click_icon-এর জন্য Ollama vision মডেল (আগে টানতে হবে: ollama pull llava)
OLLAMA_MODEL_VISION=

# ---------- ওয়েব UI লগইন (HTTP Basic Auth — সবার জন্য খোলা 0.0.0.0 এড্রেসে চলে বলে বাধ্যতামূলক) ----------
# খালি রাখলে সার্ভার প্রথমবার চালু হওয়ার সময় নিজে থেকে একটা র‍্যান্ডম পাসওয়ার্ড
# জেনারেট করে এখানেই লিখে দেবে (এবং সার্ভার লগে/journalctl-এ দেখাবে)।
AGNO_UI_USERNAME=agno
AGNO_UI_PASSWORD=

# ---------- Database ----------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agno_system

# ---------- Search (ঐচ্ছিক, না দিলে DuckDuckGo/Wikipedia দিয়েই চলবে) ----------
TAVILY_API_KEY=
SERPER_API_KEY=

# ---------- Communication ----------
SLACK_TOKEN=
GMAIL_CREDENTIALS_PATH=
EMAIL_SENDER=
EMAIL_PASSWORD=

# ---------- Productivity ----------
NOTION_TOKEN=
GITHUB_ACCESS_TOKEN=
GITLAB_ACCESS_TOKEN=
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# ---------- Media generation ----------
OPENAI_API_KEY=
FAL_KEY=
ELEVEN_LABS_API_KEY=

# ---------- Browser Automation ----------
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
AGENTQL_API_KEY=

# ---------- Coding Team (ঐচ্ছিক সন্ডবক্স/এডিট টুল) ----------
MORPH_API_KEY=
E2B_API_KEY=
DAYTONA_API_KEY=

# ---------- Social Media Team ----------
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
YOUTUBE_API_KEY=
TELEGRAM_TOKEN=
X_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
DISCORD_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# ---------- E-commerce Team ----------
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_STORE_URL=

# ---------- IoT Team (Home Assistant) ----------
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# ---------- Personal Knowledge Team ----------
PERSONAL_DOCS_DIR=./personal_docs

# ---------- Security Team ----------
# Fernet key জেনারেট করতে: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECURITY_VAULT_KEY=

# ---------- Guardrail (approval-gate) ----------
APPROVAL_TIMEOUT_SECONDS=300

# ---------- Voice Daemon (wake-word, always-listening) ----------
AGNO_API_BASE=http://localhost:8000
WAKE_WORDS=hey agno,হে আগ্নো,জার্ভিস,jarvis
WHISPER_MODEL_SIZE=tiny
MIC_SAMPLE_RATE=16000
LISTEN_CHUNK_SECONDS=4
COMMAND_SECONDS=6
